<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="200%p"
        android:centerX="0.5"
        android:centerY="0.42"
        android:startColor="#DC143C"
        android:centerColor="#B0102E"
        android:endColor="#5C0015" />
</shape>


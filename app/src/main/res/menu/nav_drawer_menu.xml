<?xml version="1.0" encoding="utf-8"?>
<!--
    nav_drawer_menu.xml — SajhaPulse Super App Navigation Menu
    ═══════════════════════════════════════════════════════════════════
    Groups:
      Group 1 (core)      : Home
      Group 2 (services)  : Sajha Patrika, Paisa & Bazaar, Sajha Patro,
                            Nagarik Tools
      Group 3 (emergency) : Apatkal Helplines (non-checkable, red icon
                            tint applied in MainActivity)
      Group 4 (account)   : Settings, Help & Support
      Group 5 (logout)    : Logout (non-checkable, red accent)
    ═══════════════════════════════════════════════════════════════════
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Core ────────────────────────────────────────────────────── -->
    <group android:id="@+id/group_core" android:checkableBehavior="single">

        <item
            android:id="@+id/nav_home"
            android:icon="@drawable/ic_home"
            android:title="@string/nav_home"
            android:checked="true" />

    </group>

    <!-- ── Nagarik Services ─────────────────────────────────────────── -->
    <group android:id="@+id/group_services" android:checkableBehavior="single">

        <!--
            Sajha Patrika — aggregated news from Kantipur, Ratopati,
            OnlineKhabar, Setopati, etc.
        -->
        <item
            android:id="@+id/nav_patrika"
            android:icon="@drawable/ic_language"
            android:title="@string/nav_patrika" />

        <!--
            Paisa &amp; Bazaar — NEPSE live index, NRB Forex rates,
            Gold &amp; Silver prices, remittance tracker.
        -->
        <item
            android:id="@+id/nav_markets"
            android:icon="@drawable/ic_trending"
            android:title="@string/nav_markets" />

        <!--
            Sajha Patro — Bikram Sambat calendar with Tithis, festivals,
            auspicious dates (Shubha Muhurta), public holidays.
        -->
        <item
            android:id="@+id/nav_patro"
            android:icon="@drawable/ic_calendar"
            android:title="@string/nav_patro" />

        <!--
            Nagarik Tools — citizen utility dashboard:
              • AQI (Kathmandu Valley)
              • Loadshedding schedule (NEA API)
              • Water tanker status
              • E-Gov portal shortcuts (Nagarikta, PAN, etc.)
        -->
        <item
            android:id="@+id/nav_nagarik"
            android:icon="@drawable/ic_services"
            android:title="@string/nav_nagarik_tools" />

    </group>

    <!-- ── Emergency (non-checkable, icon tinted red in MainActivity) ─ -->
    <!--
        Apatkal Helplines — one-tap dial:
          • Police Control Room : 100
          • Nepal Ambulance     : 1298
          • Fire Brigade        : 101
          • APF Disaster        : 1144
    -->
    <group android:id="@+id/group_emergency" android:checkableBehavior="none">

        <item
            android:id="@+id/nav_emergency"
            android:icon="@drawable/ic_notifications"
            android:title="@string/nav_emergency" />

    </group>

    <!-- ── Account &amp; Settings ────────────────────────────────────── -->
    <group android:id="@+id/group_account" android:checkableBehavior="single">

        <item
            android:id="@+id/nav_settings"
            android:icon="@drawable/ic_settings"
            android:title="@string/nav_settings" />

        <item
            android:id="@+id/nav_help"
            android:icon="@drawable/ic_person"
            android:title="@string/nav_help" />

    </group>

    <!-- ── Logout (non-checkable, separate group) ────────────────────── -->
    <group android:id="@+id/group_logout" android:checkableBehavior="none">

        <item
            android:id="@+id/nav_logout"
            android:icon="@drawable/ic_logout"
            android:title="@string/nav_logout" />

    </group>

</menu>
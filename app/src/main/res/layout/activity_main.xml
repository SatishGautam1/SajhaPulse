<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    ─────────────────────────────────────────────────────────────────────
    MainActivity layout — Night Tech / SajhaPulse
    • DrawerLayout root (Navigation Drawer sidebar)
    • CoordinatorLayout content (AppBarLayout + NestedScrollView)
    • MaterialToolbar with menu icon and avatar
    • Dashboard cards with 3D elevation + translationZ
    • NavigationView sidebar (header + menu items)
    ─────────────────────────────────────────────────────────────────────
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity"
    tools:openDrawer="start">

    <!-- ══════════════════════════════════════════════════════════════
         MAIN CONTENT — CoordinatorLayout with collapsing toolbar
    ══════════════════════════════════════════════════════════════════ -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main_coordinator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:fitsSystemWindows="true">

        <!-- ── AppBarLayout with MaterialToolbar ──────────────────── -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/toolbar_background"
            android:elevation="8dp"
            app:liftOnScroll="true"
            app:liftOnScrollTargetViewId="@id/main_scroll">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/main_toolbar"
                style="@style/Widget.NightTech.Toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:navigationIcon="@drawable/ic_menu"
                app:navigationIconTint="@color/on_surface"
                app:titleTextAppearance="@style/TextAppearance.NightTech.TitleLarge">

                <!-- Greeting text inside toolbar (left side, after nav icon) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="start">

                    <TextView
                        android:id="@+id/toolbar_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font_family"
                        android:text="Good morning,"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/toolbar_user_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font_family"
                        android:text="@string/app_name"
                        android:textColor="@color/toolbar_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Avatar / notification icon (right-aligned) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginEnd="4dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/toolbar_notify_btn"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Notifications"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/on_surface_variant" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/toolbar_avatar"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="8dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_account_circle"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.NightTech.Hero"
                        app:strokeColor="@color/secondary"
                        app:strokeWidth="1.5dp" />

                </LinearLayout>

            </com.google.android.material.appbar.MaterialToolbar>

        </com.google.android.material.appbar.AppBarLayout>

        <!-- ── Scrollable Dashboard Content ─────────────────────── -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/main_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="24dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <!-- ══ LIVE RATE HERO CARD ════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_live_rate"
                    style="@style/Widget.NightTech.CardView.Hero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:translationZ="8dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp">

                        <!-- Live indicator dot -->
                        <View
                            android:id="@+id/live_dot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_live_dot"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="@font/main_font_family"
                            android:letterSpacing="0.06"
                            android:text="LIVE"
                            android:textColor="@color/success"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="@id/live_dot"
                            app:layout_constraintStart_toEndOf="@id/live_dot"
                            app:layout_constraintTop_toTopOf="@id/live_dot" />

                        <!-- Rate label -->
                        <TextView
                            android:id="@+id/rate_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/main_font_family"
                            android:text="USD / NPR"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/live_dot" />

                        <!-- Rate value — big hero number -->
                        <TextView
                            android:id="@+id/rate_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/main_font_family"
                            android:letterSpacing="-0.025"
                            android:text="—"
                            android:textColor="@color/on_surface"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/rate_label" />

                        <!-- Change badge -->
                        <com.google.android.material.chip.Chip
                            android:id="@+id/rate_change_chip"
                            style="@style/Widget.NightTech.Chip.Success"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+0.00%"
                            android:textSize="12sp"
                            app:layout_constraintBottom_toBottomOf="@id/rate_value"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@id/rate_value" />

                        <!-- Last updated -->
                        <TextView
                            android:id="@+id/rate_last_updated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/main_font_family"
                            android:text="Fetching data..."
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/rate_value" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ══ SECTION HEADER — Quick Stats ══════════════ -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/main_font_family"
                    android:letterSpacing="-0.01"
                    android:text="Quick Stats"
                    android:textColor="@color/on_surface"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- ══ STATS CARD ROW — side by side ════════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Gold Rate Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_gold"
                        style="@style/Widget.NightTech.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:translationZ="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/main_font_family"
                                android:letterSpacing="0.04"
                                android:text="GOLD"
                                android:textColor="@color/warning"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/gold_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/main_font_family"
                                android:text="—"
                                android:textColor="@color/on_surface"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/main_font_family"
                                android:text="NPR / tola"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Silver Rate Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_silver"
                        style="@style/Widget.NightTech.CardView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:translationZ="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/main_font_family"
                                android:letterSpacing="0.04"
                                android:text="SILVER"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/silver_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/main_font_family"
                                android:text="—"
                                android:textColor="@color/on_surface"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/main_font_family"
                                android:text="NPR / tola"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="11sp" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ══ FOREX TABLE CARD ═══════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_forex"
                    style="@style/Widget.NightTech.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:translationZ="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/main_font_family"
                                android:text="Forex Rates"
                                android:textColor="@color/on_surface"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/forex_see_all"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/main_font_family"
                                android:text="See all"
                                android:textColor="@color/secondary"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <!-- Table container — rows injected programmatically -->
                        <LinearLayout
                            android:id="@+id/forex_table_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="vertical" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- ══ MARKET NEWS CARD ═══════════════════════════ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_news"
                    style="@style/Widget.NightTech.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:translationZ="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/main_font_family"
                            android:text="Market Updates"
                            android:textColor="@color/on_surface"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/news_placeholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/main_font_family"
                            android:lineSpacingMultiplier="1.5"
                            android:text="Loading latest market updates…"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="13sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- FAB — quick currency converter -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_convert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:fontFamily="@font/main_font_family"
            android:text="Convert"
            android:textStyle="bold"
            app:backgroundTint="@color/secondary"
            app:elevation="12dp"
            app:icon="@drawable/ic_swap_horiz"
            app:iconTint="@color/on_secondary"
            app:tint="@color/on_secondary" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ══════════════════════════════════════════════════════════════
         NAVIGATION DRAWER — Sidebar
    ══════════════════════════════════════════════════════════════════ -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_main"
        app:itemBackground="@drawable/nav_item_background"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:itemTextAppearance="@style/TextAppearance.NightTech.TitleSmall"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
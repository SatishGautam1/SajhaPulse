<?xml version="1.0" encoding="utf-8"?>
<!--
    item_forex_rate.xml — single row in ForexFragment's RecyclerView
    Columns must match fragment_forex.xml header weights:
      CURRENCY  weight=2.2  |  UNIT  weight=0.6  |  BUY  weight=1  |  SELL  weight=1
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingEnd="4dp"
    android:paddingStart="4dp">

    <!-- ── FLAG + ISO + NAME (weight 2.2) ─────────────────────── -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.2"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Flag emoji -->
        <TextView
            android:id="@+id/tv_forex_flag"
            android:layout_width="24dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/main_font_family"
            android:gravity="center"
            android:textSize="16sp"
            tools:text="🇺🇸" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <!-- ISO code, e.g. "USD" -->
            <TextView
                android:id="@+id/tv_forex_iso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/main_font_family"
                android:textColor="@color/on_surface"
                android:textFontWeight="700"
                android:textSize="13sp"
                tools:text="USD" />

            <!-- Full name, e.g. "U.S. Dollar" -->
            <TextView
                android:id="@+id/tv_forex_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.55"
                android:fontFamily="@font/main_font_family"
                android:maxLines="1"
                android:textColor="@color/on_surface"
                android:textSize="10sp"
                tools:text="U.S. Dollar" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── UNIT (weight 0.6) ───────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_forex_unit"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:alpha="0.60"
        android:fontFamily="@font/main_font_family"
        android:gravity="center"
        android:textColor="@color/on_surface"
        android:textSize="11sp"
        tools:text="per 1" />

    <!-- ── BUY rate (weight 1) ─────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_forex_buy"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/main_font_family"
        android:gravity="end"
        android:textColor="@color/on_surface"
        android:textSize="12sp"
        tools:text="133.27" />

    <!-- ── SELL rate (weight 1) ────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_forex_sell"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="@font/main_font_family"
        android:gravity="end"
        android:textColor="@color/on_surface"
        android:textFontWeight="600"
        android:textSize="12sp"
        tools:text="133.90" />

</LinearLayout>
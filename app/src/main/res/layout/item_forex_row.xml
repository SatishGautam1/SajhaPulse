<?xml version="1.0" encoding="utf-8"?>
<!--
    item_forex_row.xml
    Layout to be inflated dynamically into forex_table_container
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingVertical="12dp">

    <!-- Currency Flag / Icon -->
    <ImageView
        android:id="@+id/row_currency_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:contentDescription="Currency Flag"
        android:src="@drawable/ic_language" />

    <!-- Currency Name -->
    <TextView
        android:id="@+id/row_currency_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:text="EUR"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Rate Values Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/row_buy_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="140.50"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buy Rate"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<!--
    nav_header_main.xml — Navigation Drawer Header
    ══════════════════════════════════════════════════════════════════
    Height: 200dp (standard M3 nav-drawer header)
    background: primary_variant (slightly lighter than toolbar so the
                header stands apart from both the status bar above and
                the drawer items below)
    fitsSystemWindows: handled by the parent NavigationView — the header
                receives the top inset automatically so avatar never
                overlaps the status bar.

    Layout (top → bottom, pinned to bottom via ConstraintLayout bias):
      • Decorative offset circle (top-right, overflows)
      • LIVE dot + SajhaPulse label (top-left brand)
      • [spacer fills middle]
      • Avatar circle (64 dp, cyan stroke)
      • Display name (bold white, 16sp)
      • Email / guest tag (semi-transparent white, 12sp)
    ══════════════════════════════════════════════════════════════════
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:background="@color/primary"
    android:padding="20dp">

    <!-- Decorative circle — top-right overflow for depth -->
    <View
        android:id="@+id/header_deco"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:alpha="0.10"
        android:background="@drawable/bg_circle_primary_light"
        android:layout_marginEnd="-32dp"
        android:layout_marginTop="-32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Brand row: live dot + app name -->
    <LinearLayout
        android:id="@+id/header_brand_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_live_dot" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="@font/main_font_family"
            android:letterSpacing="0.10"
            android:text="@string/app_name"
            android:textAllCaps="true"
            android:textColor="@color/success_light"
            android:textFontWeight="700"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Avatar — circular, loaded at runtime (Glide / Coil) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/nav_header_avatar"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="@string/cd_user_avatar"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_account_circle"
        app:strokeColor="@color/secondary"
        app:strokeWidth="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_header_name" />

    <!-- Display name -->
    <TextView
        android:id="@+id/nav_header_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:ellipsize="end"
        android:fontFamily="@font/main_font_family"
        android:maxLines="1"
        android:text="@string/placeholder_user_name"
        android:textColor="@color/on_primary"
        android:textFontWeight="700"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/nav_header_email" />

    <!-- Email -->
    <TextView
        android:id="@+id/nav_header_email"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:alpha="0.70"
        android:ellipsize="end"
        android:fontFamily="@font/main_font_family"
        android:maxLines="1"
        android:text="@string/placeholder_user_email"
        android:textColor="@color/on_primary"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
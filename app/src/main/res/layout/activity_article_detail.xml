<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_article_detail.xml — Full article reader.
    Hero image → category badge → title → timestamp → body text.
    Crimson AppBar with back arrow.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <!-- Fixed crimson AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_background"
        android:elevation="4dp"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_article"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_background"
            app:contentInsetStart="0dp"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/on_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable article content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero image -->
            <ImageView
                android:id="@+id/article_hero_image"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                android:src="@color/md_theme_primaryContainer" />

            <!-- Article metadata + body -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Category badge -->
                <TextView
                    android:id="@+id/article_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_bs_badge"
                    android:fontFamily="@font/main_font_family"
                    android:paddingBottom="3dp"
                    android:paddingEnd="10dp"
                    android:paddingStart="10dp"
                    android:paddingTop="3dp"
                    android:textColor="@color/md_theme_primary"
                    android:textFontWeight="800"
                    android:textSize="10sp"
                    tools:text="POLITICS" />

                <!-- Article title -->
                <TextView
                    android:id="@+id/article_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/main_font_family"
                    android:lineSpacingMultiplier="1.3"
                    android:textColor="@color/on_surface"
                    android:textFontWeight="800"
                    android:textSize="20sp"
                    tools:text="Nepal Rastra Bank raises repo rate to curb inflation pressure" />

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/article_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:alpha="0.55"
                    android:fontFamily="@font/main_font_family"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    tools:text="19 Baisakh 2083  •  10:30 AM" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="14dp"
                    android:alpha="0.12"
                    android:background="@color/on_surface" />

                <!-- Article body -->
                <TextView
                    android:id="@+id/article_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/main_font_family"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp"
                    tools:text="Full article content appears here. Admin writes this in the Firebase console or admin panel." />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
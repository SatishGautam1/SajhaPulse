<?xml version="1.0" encoding="utf-8"?>
<!--
    content_main.xml — SajhaPulse Main Dashboard Panel
    ═══════════════════════════════════════════════════════════════════
    System Bars:
      • Status bar  : crimson (#DC143C), WHITE icons — set via
        SystemBarHelper.applyAppBars(). AppBarLayout with
        fitsSystemWindows="true" absorbs the top inset so the
        crimson toolbar sits seamlessly under the crimson status bar.
      • Nav bar     : crimson (#DC143C), WHITE gesture handle.
        NestedScrollView has paddingBottom to clear nav bar height.

    Design language: Modern Traditional Nepali — Paati/Dhara-inspired
    heritage geometry layered with Material 3 surfaces and 3D depth
    animations on the DateTime hero card.

    Structure:
      ① AppBarLayout + Toolbar (crimson, always pinned)
      ② NestedScrollView body:
           • DateTime Hero Card  (3D-style with layered depth)
           • Quick Services grid (2 × 2 icon pills)
           • Daily Highlight     (accent announcement card)
    ═══════════════════════════════════════════════════════════════════
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinator_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false">

    <!-- ══════════════════════════════════════════════════════════════
          APP BAR — Crimson, edge-to-edge.
          fitsSystemWindows="true" here lets AppBarLayout absorb the
          status-bar inset automatically, padding the Toolbar below the
          crimson system status bar without any extra Java code.
         ══════════════════════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/toolbar_background"
        android:elevation="0dp"
        android:fitsSystemWindows="true"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@id/scroll_dashboard">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/toolbar_background"
            android:paddingEnd="4dp"
            app:contentInsetStart="0dp"
            app:contentInsetStartWithNavigation="0dp"
            app:navigationIcon="@drawable/ic_menu"
            app:navigationIconTint="@color/on_primary">

            <!-- Two-line greeting block -->
            <LinearLayout
                android:id="@+id/layout_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp">

                <ImageView
                    android:id="@+id/iv_greeting_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_sun"
                    app:tint="@color/on_primary" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.85"
                        android:fontFamily="@font/main_font_family"
                        android:maxLines="1"
                        android:text="@string/greeting_morning"
                        android:textColor="@color/on_primary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_greeting_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/main_font_family"
                        android:maxLines="1"
                        android:text="@string/default_user_name"
                        android:textColor="@color/toolbar_title"
                        android:textFontWeight="700"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right-side action cluster -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|center_vertical"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="8dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <ImageButton
                        android:id="@+id/toolbar_notify_btn"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="8dp"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/on_primary" />

                    <View
                        android:id="@+id/notification_badge"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginEnd="7dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/bg_notification_badge"
                        android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════════════════════
          SCROLLABLE BODY
          paddingBottom ensures content clears the crimson nav bar.
          clipToPadding="false" allows cards to scroll under the bar.
         ══════════════════════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_dashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        android:scrollbars="none"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingEnd="16dp"
            android:paddingStart="16dp"
            android:paddingTop="12dp">

            <!-- ══════════════════════════════════════════════════════
                  ① DATE-TIME HERO CARD
                  Design: Traditional Nepali "Paati" (open shrine pavilion)
                  aesthetics — deep crimson-to-maroon gradient background,
                  white mandala-inspired decorative geometry, Bikram Sambat
                  given visual PRIMACY (larger, colored), AD date secondary.
                  3D depth: achieved via layered Views with different
                  elevations, a subtle shadow card behind the main card,
                  and a ScaleAnimation + RotateAnimation applied in Java
                  (see MainActivity.animateDateTimeCard()).
                 ══════════════════════════════════════════════════════ -->

            <!--
                Shadow/depth layer — sits 4dp behind the main card,
                slightly offset down-right. Same corner radius but
                slightly larger. Gives a "lifted slab" 3D feel.
            -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="0dp"
                android:paddingBottom="6dp"
                android:paddingEnd="6dp">

                <!-- Depth shadow layer (drawn first = behind) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_marginTop="6dp"
                    app:cardBackgroundColor="#7B0A1E"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp" />

                <!-- MAIN Hero Card (drawn on top of shadow layer) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_datetime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/md_theme_primary"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    app:rippleColor="#33FFFFFF"
                    app:strokeColor="#33FFFFFF"
                    app:strokeWidth="1dp">

                    <!-- Background decorative geometry layer — Mandala arcs -->
                    <View
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="end|top"
                        android:layout_marginEnd="-60dp"
                        android:layout_marginTop="-60dp"
                        android:alpha="0.07"
                        android:background="@drawable/bg_mandala_circle" />

                    <!-- Second decorative arc — bottom-left -->
                    <View
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="start|bottom"
                        android:layout_marginBottom="-40dp"
                        android:layout_marginStart="-40dp"
                        android:alpha="0.05"
                        android:background="@drawable/bg_mandala_circle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <!-- ── Top Row: Day name + LIVE badge ─────────── -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_day_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/main_font_family"
                                android:letterSpacing="0.14"
                                android:textAllCaps="true"
                                android:textColor="#CCFFFFFF"
                                android:textFontWeight="700"
                                android:textSize="11sp"
                                tools:text="SATURDAY" />

                            <!-- LIVE badge — pulsing dot + label -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_live_badge"
                                android:gravity="center_vertical"
                                android:orientation="horizontal"
                                android:paddingEnd="8dp"
                                android:paddingStart="6dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp">

                                <View
                                    android:id="@+id/view_live_dot"
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:layout_marginEnd="5dp"
                                    android:background="@drawable/bg_live_dot" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/main_font_family"
                                    android:letterSpacing="0.08"
                                    android:text="LIVE"
                                    android:textColor="#FFFFFF"
                                    android:textFontWeight="800"
                                    android:textSize="9sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- ── Large Time Display ──────────────────────── -->
                        <!--
                            Time is displayed with enormous weight to own
                            the visual hierarchy. Seconds shown small + right.
                        -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_time_main"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/main_font_family"
                                android:letterSpacing="-0.03"
                                android:textColor="#FFFFFF"
                                android:textFontWeight="900"
                                android:textSize="56sp"
                                tools:text="10:45" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_am_pm"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/main_font_family"
                                    android:textColor="#CCFFFFFF"
                                    android:textFontWeight="700"
                                    android:textSize="16sp"
                                    tools:text="AM" />

                                <TextView
                                    android:id="@+id/tv_seconds"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:fontFamily="@font/main_font_family"
                                    android:textColor="#99FFFFFF"
                                    android:textFontWeight="400"
                                    android:textSize="12sp"
                                    tools:text=":32" />
                            </LinearLayout>
                        </LinearLayout>

                        <!--
                            Heritage rule — thin gold-tinted divider that
                            evokes the brass/gilded details of Nepali temples.
                        -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:layout_marginTop="16dp"
                            android:alpha="0.30"
                            android:background="#FFD700" />

                        <!-- ── Dual Calendar Block ─────────────────────── -->
                        <!--
                            B.S. is PRIMARY — larger font, white color,
                            gold label. A.D. is secondary — muted, smaller.
                            This intentional hierarchy respects that Nepali
                            users primarily live by the Bikram Sambat calendar.
                        -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- B.S. Block (primary) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1.2"
                                android:orientation="vertical">

                                <!-- Gold "B.S." badge -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_bs_badge"
                                    android:fontFamily="@font/main_font_family"
                                    android:paddingEnd="6dp"
                                    android:paddingStart="6dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"
                                    android:text="विक्रम सम्वत्"
                                    android:textColor="#FFD700"
                                    android:textFontWeight="800"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/tv_bs_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/main_font_family"
                                    android:textColor="#FFFFFF"
                                    android:textFontWeight="800"
                                    android:textSize="18sp"
                                    tools:text="२० बैशाख २०८३" />

                                <TextView
                                    android:id="@+id/tv_bs_date_latin"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:alpha="0.70"
                                    android:fontFamily="@font/main_font_family"
                                    android:textColor="#FFFFFF"
                                    android:textFontWeight="400"
                                    android:textSize="12sp"
                                    tools:text="20 Baishakh 2083" />
                            </LinearLayout>

                            <!-- Vertical gold rule separator -->
                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:layout_marginHorizontal="16dp"
                                android:alpha="0.30"
                                android:background="#FFD700" />

                            <!-- A.D. Block (secondary) -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_weight="0.8"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/main_font_family"
                                    android:letterSpacing="0.08"
                                    android:text="A.D."
                                    android:textColor="#AAFFFFFF"
                                    android:textFontWeight="700"
                                    android:textSize="9sp" />

                                <TextView
                                    android:id="@+id/tv_ad_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/main_font_family"
                                    android:textColor="#CCFFFFFF"
                                    android:textFontWeight="600"
                                    android:textSize="14sp"
                                    tools:text="2 May 2026" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                    <!-- end card content LinearLayout -->

                </com.google.android.material.card.MaterialCardView>
                <!-- end main hero card -->

            </FrameLayout>
            <!-- end 3D depth FrameLayout -->

            <!-- ══════════════════════════════════════════════════════
                  ② QUICK SERVICES SECTION HEADER
                 ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Crimson accent pip before section title -->
                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/md_theme_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/main_font_family"
                    android:text="Quick Services"
                    android:textColor="@color/on_surface"
                    android:textFontWeight="700"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════
                  ③ QUICK ACCESS GRID — 2 × 2
                  Each cell: icon pill (circle) + label beneath.
                  Pill background is primaryContainer (soft rose/crimson).
                 ══════════════════════════════════════════════════════ -->

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <!-- Markets -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_nav_markets"
                    style="@style/Widget.SajhaPulse.CardView"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <!-- Circular icon container -->
                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_pill_primary">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_trending_up"
                                app:tint="@color/md_theme_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/main_font_family"
                            android:text="Markets"
                            android:textColor="@color/on_surface"
                            android:textFontWeight="600"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Forex -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_nav_forex"
                    style="@style/Widget.SajhaPulse.CardView"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_pill_primary">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_swap_horiz"
                                app:tint="@color/md_theme_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/main_font_family"
                            android:text="Forex Rates"
                            android:textColor="@color/on_surface"
                            android:textFontWeight="600"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <!-- News -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_nav_news"
                    style="@style/Widget.SajhaPulse.CardView"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_pill_primary">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_language"
                                app:tint="@color/md_theme_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/main_font_family"
                            android:text="News Pulse"
                            android:textColor="@color/on_surface"
                            android:textFontWeight="600"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Utilities -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_nav_utilities"
                    style="@style/Widget.SajhaPulse.CardView"
                    android:layout_width="0dp"
                    android:layout_height="96dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_icon_pill_primary">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_services"
                                app:tint="@color/md_theme_primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/main_font_family"
                            android:text="Utilities"
                            android:textColor="@color/on_surface"
                            android:textFontWeight="600"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════
                  ④ DAILY HIGHLIGHT / ANNOUNCEMENT CARD
                  Uses secondary color (deeper red-brown) for contrast
                  with the white card grid above it.
                 ══════════════════════════════════════════════════════ -->

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="3dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/md_theme_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/main_font_family"
                    android:text="Today's Highlight"
                    android:textColor="@color/on_surface"
                    android:textFontWeight="700"
                    android:textSize="15sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_daily_pulse"
                style="@style/Widget.SajhaPulse.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/md_theme_primary"
                app:cardCornerRadius="20dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <!-- Icon container -->
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_highlight_icon_bg">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_notifications"
                            app:tint="#FFFFFF" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.80"
                            android:fontFamily="@font/main_font_family"
                            android:letterSpacing="0.05"
                            android:text="NOTIFICATION"
                            android:textAllCaps="true"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tv_daily_pulse_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/main_font_family"
                            android:lineSpacingMultiplier="1.3"
                            android:text="Set up your profile to receive personalized alerts."
                            android:textColor="#FFFFFF"
                            android:textFontWeight="600"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Chevron -->
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.60"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#FFFFFF" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
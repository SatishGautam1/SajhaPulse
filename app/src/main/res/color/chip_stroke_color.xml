<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Border color when selected (matches background for a solid look) -->
    <item android:color="@color/md_theme_primary" android:state_selected="true" />
    <item android:color="@color/md_theme_primary" android:state_checked="true" />

    <!-- Border color when idle -->
    <item android:color="@color/md_theme_outline" />
</selector>
<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Color when the chip is selected (e.g., active filter) -->
    <item android:color="@color/md_theme_primary" android:state_selected="true" />
    <item android:color="@color/md_theme_primary" android:state_checked="true" />

    <!-- Color when the chip is pressed but not yet selected -->
    <item android:color="@color/md_theme_primaryContainer" android:state_pressed="true" />

    <!-- Default idle state (transparent or subtle surface color) -->
    <item android:color="@android:color/transparent" />
</selector>
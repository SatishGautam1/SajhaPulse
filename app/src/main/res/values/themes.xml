<?xml version="1.0" encoding="utf-8"?>
<!--
    SajhaPulse — themes.xml  (res/values/themes.xml)
    Material Design 3 · Light Theme · Nepal Identity
    UPDATED: Universal crimson system bars with white icons across ALL screens.
-->
<resources>

    <!-- ═══════════════════════════════════════════════════════════════
         1. BASE APP THEME
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.SajhaPulse" parent="Theme.Material3.Light.NoActionBar">

        <!-- ── Color Scheme ─────────────────────────────────────────── -->
        <item name="colorPrimary">@color/md_theme_primary</item>
        <item name="colorOnPrimary">@color/md_theme_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_onPrimaryContainer</item>

        <item name="colorSecondary">@color/md_theme_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_onSecondaryContainer</item>

        <item name="colorTertiary">@color/md_theme_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_onTertiaryContainer</item>

        <item name="colorError">@color/md_theme_error</item>
        <item name="colorOnError">@color/md_theme_onError</item>
        <item name="colorErrorContainer">@color/md_theme_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_onErrorContainer</item>

        <!-- ── Background & Surface ──────────────────────────────────── -->
        <item name="android:colorBackground">@color/md_theme_background</item>
        <item name="colorOnBackground">@color/md_theme_onBackground</item>
        <item name="colorSurface">@color/md_theme_surface</item>
        <item name="colorOnSurface">@color/md_theme_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_onSurfaceVariant</item>
        <item name="colorSurfaceTint">@color/md_theme_surfaceTint</item>

        <!-- ── Inverse ───────────────────────────────────────────────── -->
        <item name="colorSurfaceInverse">@color/md_theme_inverseSurface</item>
        <item name="colorOnSurfaceInverse">@color/md_theme_inverseOnSurface</item>
        <item name="colorPrimaryInverse">@color/md_theme_inversePrimary</item>
        <item name="inverseSurface">@color/md_theme_inverseSurface</item>
        <item name="inverseOnSurface">@color/md_theme_inverseOnSurface</item>
        <item name="inversePrimary">@color/md_theme_inversePrimary</item>

        <!-- ── Outline ───────────────────────────────────────────────── -->
        <item name="colorOutline">@color/md_theme_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_outlineVariant</item>

        <!-- ══════════════════════════════════════════════════════════
             SYSTEM BARS — Universal Crimson Theme
             ALL screens use crimson (#DC143C) for both status bar and
             navigation bar, with WHITE icons for battery, WiFi, signal,
             clock, and gesture handle throughout the entire app.
             SystemBarHelper.applyAppBars(activity) enforces this at
             runtime for every Activity.
        ══════════════════════════════════════════════════════════════ -->

        <!-- Crimson status bar — same as primary color -->
        <item name="android:statusBarColor">@color/md_theme_primary</item>

        <!-- Dark status bar icons = false → WHITE icons on crimson -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Crimson nav bar — same as primary color -->
        <item name="android:navigationBarColor">@color/md_theme_primary</item>

        <!-- Dark nav bar icons = false → WHITE gesture handle on crimson -->
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Prevents white flash on launch -->
        <item name="android:windowBackground">@color/md_theme_background</item>

        <!-- Allows drawing behind system bars -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- ── Component Style Overrides ────────────────────────────── -->
        <item name="materialCardViewStyle">@style/Widget.SajhaPulse.CardView</item>
        <item name="bottomNavigationStyle">@style/Widget.SajhaPulse.BottomNavigationView</item>
        <item name="chipStyle">@style/Widget.SajhaPulse.Chip</item>
        <item name="materialButtonStyle">@style/Widget.SajhaPulse.Button</item>
        <item name="textInputStyle">@style/Widget.SajhaPulse.TextInputLayout</item>
        <item name="toolbarStyle">@style/Widget.SajhaPulse.Toolbar</item>
        <item name="floatingActionButtonStyle">@style/Widget.SajhaPulse.FAB</item>

    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         2. SPLASH THEME
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Theme.SajhaPulse.Splash" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/sajha_splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/md_theme_onPrimary</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.SajhaPulse</item>

        <!-- Crimson splash → white icons consistent with the rest of the app -->
        <item name="android:statusBarColor">@color/sajha_splash_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/sajha_splash_background</item>
        <item name="android:windowLightNavigationBar">false</item>

    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         3. CARD VIEW STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.SajhaPulse.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/md_theme_surfaceContainerLow</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="rippleColor">@color/md_theme_primaryContainer</item>
    </style>

    <style name="Widget.SajhaPulse.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.SajhaPulse.CardView.Hero" parent="Widget.SajhaPulse.CardView">
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/md_theme_primaryContainer</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         4. BOTTOM NAVIGATION VIEW
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Widget.SajhaPulse.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/md_theme_surface</item>
        <item name="itemActiveIndicatorColor">@color/sajha_nav_indicator</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.SajhaPulse.BottomNav.ActiveIndicator</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.SajhaPulse.BottomNav.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.SajhaPulse.BottomNav.Inactive</item>
        <item name="itemIconSize">24dp</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Widget.SajhaPulse.BottomNav.ActiveIndicator"
        parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:width">64dp</item>
        <item name="android:height">32dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.SajhaPulse.BottomNav.Indicator</item>
    </style>

    <style name="ShapeAppearance.SajhaPulse.BottomNav.Indicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="TextAppearance.SajhaPulse.BottomNav.Active"
        parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/sajha_nav_selected</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SajhaPulse.BottomNav.Inactive"
        parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/sajha_nav_unselected</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         5. CHIP
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Widget.SajhaPulse.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">8dp</item>
        <item name="chipBackgroundColor">@color/md_theme_surfaceVariant</item>
        <item name="chipStrokeColor">@color/md_theme_outlineVariant</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:textColor">@color/md_theme_onSurfaceVariant</item>
    </style>

    <style name="Widget.SajhaPulse.Chip.Success" parent="Widget.SajhaPulse.Chip">
        <item name="chipBackgroundColor">@color/success_light</item>
        <item name="android:textColor">@color/success</item>
        <item name="chipStrokeColor">@color/success</item>
    </style>

    <style name="ShapeAppearance.SajhaPulse.Hero" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         6. BUTTON STYLES
         ═══════════════════════════════════════════════════════════════ -->

    <style name="Widget.SajhaPulse.Button" parent="Widget.Material3.Button">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="android:textColor">@color/md_theme_onPrimary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.SajhaPulse.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/md_theme_primary</item>
        <item name="android:textColor">@color/md_theme_primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.SajhaPulse.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/md_theme_secondary</item>
        <item name="android:textAllCaps">false</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         7. TEXT INPUT LAYOUT
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Widget.SajhaPulse.TextInputLayout"
        parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/md_theme_outline</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/md_theme_primary</item>
        <item name="startIconTint">@color/md_theme_onSurfaceVariant</item>
        <item name="endIconTint">@color/md_theme_primary</item>
    </style>

    <style name="Widget.SajhaPulse.TextInputLayout.Dense"
        parent="Widget.SajhaPulse.TextInputLayout">
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         8. TOOLBAR
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Widget.SajhaPulse.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/md_theme_surface</item>
        <item name="titleTextColor">@color/md_theme_onSurface</item>
        <item name="subtitleTextColor">@color/md_theme_onSurfaceVariant</item>
        <item name="titleTextAppearance">@style/TextAppearance.SajhaPulse.Toolbar.Title</item>
        <item name="navigationIconTint">@color/md_theme_onSurface</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="TextAppearance.SajhaPulse.Toolbar.Title"
        parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.SajhaPulse.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/main_font_family</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Crimson toolbar variant — for crimson-header screens (Login, Main dashboard) -->
    <style name="Widget.SajhaPulse.Toolbar.Primary" parent="Widget.SajhaPulse.Toolbar">
        <item name="android:background">@color/md_theme_primary</item>
        <item name="titleTextColor">@color/md_theme_onPrimary</item>
        <item name="subtitleTextColor">@color/md_theme_onPrimary</item>
        <item name="navigationIconTint">@color/md_theme_onPrimary</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         9. FLOATING ACTION BUTTON
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Widget.SajhaPulse.FAB"
        parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/md_theme_primary</item>
        <item name="tint">@color/md_theme_onPrimary</item>
        <item name="fabSize">normal</item>
        <item name="shapeAppearance">@style/ShapeAppearance.SajhaPulse.FAB</item>
    </style>

    <style name="ShapeAppearance.SajhaPulse.FAB"
        parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         10. DIALOG
         ═══════════════════════════════════════════════════════════════ -->
    <style name="Dialog.SajhaPulse" parent="ThemeOverlay.Material3.Dialog">
        <item name="shapeAppearance">@style/ShapeAppearance.SajhaPulse.Dialog</item>
        <item name="colorSurface">@color/md_theme_surfaceContainerHigh</item>
    </style>

    <style name="ShapeAppearance.SajhaPulse.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>


    <!-- ═══════════════════════════════════════════════════════════════
         11. SNACKBAR THEME OVERLAY
         ═══════════════════════════════════════════════════════════════ -->
    <style name="ThemeOverlay.SajhaPulse.Snackbar" parent="">
        <item name="colorSurface">@color/md_theme_inverseSurface</item>
        <item name="colorOnSurface">@color/md_theme_inverseOnSurface</item>
        <item name="colorPrimary">@color/md_theme_inversePrimary</item>
    </style>

    <!-- Full-circle avatar shape for ShapeableImageView in drawer header -->
    <style name="ShapeAppearance.Corner.Full" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.SajhaPulse.NavItem" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50dp</item> <!-- Creates the "Pill" effect -->
    </style>

    <style name="ShapeAppearance.SajhaPulse.TopRoundedCard" parent="ShapeAppearance.Material3.MediumComponent">
        <!-- Top corners: Smooth, modern rounding -->
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>

        <!-- Bottom corners: Strictly Square to flush with screen bottom -->
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>
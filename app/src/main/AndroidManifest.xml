<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════════════════════
         PERMISSIONS
         ══════════════════════════════════════════════════════════════ -->

    <!-- Network access — required for Firebase, APIs, news feed -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Loadshedding / market alerts after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Push notifications — Android 13+ (API 33) requires explicit permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact alarm scheduling for loadshedding reminders (API 31+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:targetApi="31" />

    <!-- ══════════════════════════════════════════════════════════════
         APPLICATION
         ══════════════════════════════════════════════════════════════ -->
    <application
        android:name=".SajhaPulseApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SajhaPulse"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <!-- ══════════════════════════════════════════════════════════
             SPLASH ACTIVITY — Launcher entry point
             MUST use Theme.SajhaPulse.Splash so that the Android 12+
             SplashScreen API reads windowSplashScreen* attributes.
             Without this theme override, SplashScreen.installSplashScreen()
             is a no-op and you get the plain white system splash.
             ══════════════════════════════════════════════════════════ -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SajhaPulse.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ══════════════════════════════════════════════════════════
             LOGIN ACTIVITY
             adjustResize — pushes layout up when soft keyboard appears
             so the sign-in card is never clipped.
             Not exported — only reachable from SplashActivity.
             ══════════════════════════════════════════════════════════ -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- ══════════════════════════════════════════════════════════
             MAIN ACTIVITY
             Not exported — only reachable from LoginActivity /
             SplashActivity after auth check.
             ══════════════════════════════════════════════════════════ -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".ui.SajhaPatrikaActivity"
            android:exported="false"
            android:windowSoftInputMode="stateHidden" />

        <activity
            android:name=".ui.ArticleDetailActivity"
            android:exported="false"
            android:windowSoftInputMode="stateHidden" />

        <activity
            android:name=".ui.MarketsActivity"
            android:parentActivityName=".ui.MainActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- ══════════════════════════════════════════════════════════
             FIREBASE CLOUD MESSAGING
             ══════════════════════════════════════════════════════════ -->

        <!-- Default notification channel for all FCM messages -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="sajhapulse_alerts" />

        <!-- Default small icon shown in the system tray for FCM notifications -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notifications" />

        <!--
            NOTE: The Google Sign-In Web Client ID is NOT set via meta-data here.
            It is automatically injected by the google-services Gradle plugin from
            your google-services.json as the string resource R.string.default_web_client_id.
            Reference it in code:  getString(R.string.default_web_client_id)
            The old tag below has been removed — it used the wrong meta-data key
            and caused silent Sign-In failures on some devices:
              ✗  com.google.android.gms.auth.api.signin.WebClientId  (incorrect)
        -->

    </application>

</manifest>